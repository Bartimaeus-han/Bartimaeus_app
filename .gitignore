# Exclude heavy files generated during C++ compilation from the upload list.

# Exclude compile cache folder
/build/
/build_mac/
/build_win/
/out/

# Exclude Visual Studio and IDE temporary file
/.vs/
/.idea/
/.vscode/
/*.user/
/*.suo/
/test.cpp

# Exclude machine language executable files and libraries
*.exe
*.dll
*.lib
*.obj
*.pdb

# macOS / Unix
*.o
*.a
*.dylib
*.so
*.dSYM/

# macOS system files
.DS_Store

# Cmake auto-generated
compile_commands.json

# Local editor helper
.clangd

error.log
